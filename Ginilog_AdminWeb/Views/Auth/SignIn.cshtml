@model Ginilog_AdminWeb.Models.LoginRequset

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SignIn - Ginilog Admin Panel</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="" name="keywords">
    <meta content="" name="description">
    <!-- Favicon -->
    <!-- plugins:css -->
    <link rel="stylesheet" href="~/new/assets/vendors/mdi/css/materialdesignicons.min.css">
    <link rel="stylesheet" href="~/new/assets/vendors/css/vendor.bundle.base.css">
    <!-- endinject -->
    <!-- Plugin css for this page -->
    <!-- End plugin css for this page -->
    <!-- inject:css -->
    <!-- endinject -->
    <!-- Layout styles -->
    <link rel="stylesheet" href="~/new/assets/css/style.css">
    <!-- End layout styles -->
    <link rel="shortcut icon" href="~/new/assets/images/favicon.png" />
</head>
<body>

    <div class="container-scroller">
        <div class="container-fluid page-body-wrapper full-page-wrapper">
            <div class="row w-100 m-0">
                <div class="content-wrapper full-page-wrapper d-flex align-items-center auth login-bg">
                    <div class="card col-lg-4 mx-auto">
                        <div class="card-body px-5 py-5">
                            <h3 class="card-title text-left mb-3">Login</h3>
                            <form asp-action="SignIn">
                                <div class="form-group">
                                    <label>Email *</label>
                                    <input asp-for="Email_PhoneNo" type="email" class="form-control p_input" placeholder="name@example.com">
                                    <span asp-validation-for="Email_PhoneNo" class="text-danger"></span>
                                </div>
                                <div class="form-group">
                                    <label>Password *</label>
                                    <input asp-for="Password" type="password" class="form-control p_input" placeholder="Password">
                                    <span asp-validation-for="Password" class="text-danger"></span>
                                    <!-- Visibility toggle button -->
                                   
                                </div>
                                <p class="text-danger" style="color:red">@ViewBag.UserError</p>
                                <div class="form-group d-flex align-items-center justify-content-between">
                                    <div class="form-check">
                                        <label class="form-check-label">
                                            <input type="checkbox" class="form-check-input"> Remember me
                                        </label>
                                    </div>
                                    <a href="~/Auth/ForgetPassword" class="forgot-pass">Forgot password</a>
                                </div>
                                <div class="text-center">
                                    <button type="submit" class="btn btn-primary btn-block enter-btn">Login</button>
                                </div>
                               
                               
                            </form>
                        </div>
                    </div>
                </div>
                <!-- content-wrapper ends -->
            </div>
            <!-- row ends -->
        </div>
        <!-- page-body-wrapper ends -->
    </div>

    <!-- plugins:js -->
    <script src="~/new/assets/vendors/js/vendor.bundle.base.js"></script>
    <!-- endinject -->
    <!-- Plugin js for this page -->
    <!-- End plugin js for this page -->
    <!-- inject:js -->
    <script src="~/new/assets/js/off-canvas.js"></script>
    <script src="~/new/assets/js/hoverable-collapse.js"></script>
    <script src="~/new/assets/js/misc.js"></script>
    <script src="~/new/assets/js/settings.js"></script>
    <script src="~/new/assets/js/todolist.js"></script>
    <!-- endinject -->

    <script>
        function togglePasswordVisibility() {
            const passwordInput = document.getElementById("floatingPassword");
            const visibilityIcon = document.getElementById("visibilityIcon");

            // Toggle the password visibility
            if (passwordInput.type === "password") {
                passwordInput.type = "text";
                visibilityIcon.classList.replace("bi-eye", "bi-eye-slash");
            } else {
                passwordInput.type = "password";
                visibilityIcon.classList.replace("bi-eye-slash", "bi-eye");
            }
        }
    </script>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
</body>
</html>
