@model Ginilog_AdminWeb.Models.AddAdminRequest

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Admin - Ginilog Admin Panel</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="" name="keywords">
    <meta content="" name="description">
    <!-- plugins:css -->
    <link rel="stylesheet" href="~/new/assets/vendors/mdi/css/materialdesignicons.min.css">
    <link rel="stylesheet" href="~/new/assets/vendors/css/vendor.bundle.base.css">
    <!-- endinject -->
    <!-- Plugin css for this page -->
    <link rel="stylesheet" href="~/new/assets/vendors/jvectormap/jquery-jvectormap.css">
    <link rel="stylesheet" href="~/new/assets/vendors/flag-icon-css/css/flag-icon.min.css">
    <link rel="stylesheet" href="~/new/assets/vendors/owl-carousel-2/owl.carousel.min.css">
    <link rel="stylesheet" href="~/new/assets/vendors/owl-carousel-2/owl.theme.default.min.css">
    <!-- End plugin css for this page -->
    <!-- inject:css -->
    <!-- endinject -->
    <!-- Layout styles -->
    <link rel="stylesheet" href="~/new/assets/css/style.css">
    <!-- End layout styles -->
    <link rel="shortcut icon" href="~/new/assets/images/favicon.png" />
</head>
<body>


  
       
        <!-- Spinner End -->
        <div class="content-wrapper">

        <div style="padding-top:20px"></div>
        <p>
            <a asp-action="AllAdminUser" class="btn btn-outline-primarym-2">Back to List</a>
        </p>
    <h6 class="mb-4">Add An Admin</h6>
        <form asp-action="AddAdminUser" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-group">
                    <label>Admin Type *</label>
                    <select asp-for="AdminType" class="form-control p_input" aria-label="Floating label select example">
                        <option selected>Choose Admin Type</option>
                        <option value="Super_Admin">Super_Admin</option>
                        <option value="Admin">Admin</option> 
                        <option value="Admin">Manager</option>
                    </select>
                    <span asp-validation-for="AdminType" class="text-danger"></span>
                </div>

               <div class="form-group">
                    <label>First Name</label>
                <input asp-for="FirstName" type="text" class="form-control p_input" 
                   placeholder="First Name">
                <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
             <div class="form-group">
                    <label>Last Name</label>
               <input asp-for="SurName" type="text" class="form-control p_input" 
                   placeholder="Last Name">       
                <span asp-validation-for="SurName" class="text-danger"></span>
             </div>
            <div class="form-group">
                    <label>Email</label>
                    <input asp-for="Email" type="email" class="form-control p_input" 
                       placeholder="examle@gmail.com">
                <span asp-validation-for="Email" class="text-danger"></span>
                   <span class="text-danger">@ViewBag.UserError</span>
            </div>
           
            <div class="form-group">
                    <label>Phone Number</label>
                    <input asp-for="PhoneNo" type="tel" maxlength="11" pattern="\d{10,11}" class="form-control p_input" 
                       placeholder="Phone Number">
                <span asp-validation-for="PhoneNo" class="text-danger"></span>
                    <span class="text-danger">@ViewBag.UserError</span>
            </div>

                <div class="form-group">
                    <label>Password</label>
                    <div class="input-group">
                        <input asp-for="Password" type="password" class="form-control p_input" id="floatingPassword" placeholder="Password">
                        <div class="input-group-append">
                            <button onclick="togglePasswordVisibility()" class="btn btn-sm btn-primary" type="button" style="z-index: 1;"> <i id="visibilityIcon" class="bi bi-eye"></i></button>
                        </div>
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
           
        <div class="form-group">
                    <label>Choose Gender</label>
                    <select asp-for="Sex" class="form-control p_input" aria-label="Floating label select example">
                <option selected>Choose Gender</option>
                <option value="Male">Male</option>
                <option value="Female">Female</option>
            </select>
              
                <span asp-validation-for="Sex" class="text-danger"></span>
        </div>
        <div class="form-group">
                    <label>Staff Code</label>
                    <input asp-for="StaffCode" type="text" class="form-control p_input" 
                   placeholder="Staff Code">
            <span asp-validation-for="StaffCode" class="text-danger"></span>
        </div>
            <div class="form-group">
                    <label>Admin Address</label>
                    <input asp-for="Address" type="text" class="form-control p_input" 
                       placeholder="Admin Address">
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>
            <div class="form-group">
                    <label>Branch</label>
                <input asp-for="Branch" type="text" class="form-control p_input" 
                       placeholder="Branch">
                <span asp-validation-for="Branch" class="text-danger"></span>
            </div>
            <div class="form-group">
                    <label>State</label>
                <input asp-for="State" type="text" class="form-control p_input" 
                       placeholder="State">
                <span asp-validation-for="State" class="text-danger"></span>
            </div>
            <div class="form-group">
                    <label>City</label>
                <input asp-for="City" type="text" class="form-control p_input" 
                       placeholder="City">
                <span asp-validation-for="City" class="text-danger"></span>
            </div>

                <button type="submit" class="btn btn-primary btn-block enter-btn">Add Now</button>
    </form>
</div>



    <!-- plugins:js -->
    <script src="~/new/assets/vendors/js/vendor.bundle.base.js"></script>
    <!-- endinject -->
    <!-- Plugin js for this page -->
    <script src="~/new/assets/vendors/chart.js/Chart.min.js"></script>
    <script src="~/new/assets/vendors/progressbar.js/progressbar.min.js"></script>
    <script src="~/new/assets/vendors/jvectormap/jquery-jvectormap.min.js"></script>
    <script src="~/new/assets/vendors/jvectormap/jquery-jvectormap-world-mill-en.js"></script>
    <script src="~/new/assets/vendors/owl-carousel-2/owl.carousel.min.js"></script>
    <!-- End plugin js for this page -->
    <!-- inject:js -->
    <script src="~/new/assets/js/off-canvas.js"></script>
    <script src="~/new/assets/js/hoverable-collapse.js"></script>
    <script src="~/new/assets/js/misc.js"></script>
    <script src="~/new/assets/js/settings.js"></script>
    <script src="~/new/assets/js/todolist.js"></script>
    <!-- endinject -->
    <!-- Custom js for this page -->
    <script src="~/new/assets/js/dashboard.js"></script>
    <!-- End custom js for this page -->

    <script>
        function togglePasswordVisibility() {
            const passwordInput = document.getElementById("floatingPassword");
            const visibilityIcon = document.getElementById("visibilityIcon");

            // Toggle the password visibility
            if (passwordInput.type === "password") {
                passwordInput.type = "text";
                visibilityIcon.classList.replace("bi-eye", "bi-eye-slash");
            } else {
                passwordInput.type = "password";
                visibilityIcon.classList.replace("bi-eye-slash", "bi-eye");
            }
        }
    </script>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
</body>
</html>