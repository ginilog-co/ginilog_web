@model Ginilog_AdminWeb.Models.BookingsModel.AllAccomodationData

@{
    ViewData["Title"] = "AccommodationDetails";
    Layout = "~/Views/Shared/_NewLayout.cshtml";
}





<!-- Delete Modal -->
<div id="deleteModal" class="custom-modal">
    <div class="custom-modal-content">
        <div class="custom-modal-header">
            <h5 style="color:black" class="modal-title">Confirm Delete</h5>
            <span style="color:black" class="custom-modal-close" onclick="closeModal()">&times;</span>
        </div>
        <div class="custom-modal-body">
            <p style="color:black">   Are you sure you want to delete this Item?</p>
          
        </div>
        <div class="custom-modal-footer">
            <button onclick="closeModal()" class="btn-secondary">Cancel</button>
            <a href="@Url.Action("DeleteAccommodationConfirm", "Bookings", new { id = Model!.AccomodationDataModel!.Id })" class="btn-danger">Delete</a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12 grid-margin">
        <div class="card">
            <div class="card-body">


                <div class="row px-0 mx-0">
                    <div class="col-12 grid-margin px-0">
                        <div class="d-flex justify-content-end gap-2 px-0">

                            <div class="col-auto mb-2">
                                <button class="nav-link btn btn-danger create-new-button" onclick="openModal()">Delete</button>
                            </div>
                            <div class="col-auto mb-2">
                                <a href="~/Home/ManagerDetails/@Model.AccomodationDataModel.AdminId" class="nav-link btn btn-primary create-new-button">View Manager</a>
                            </div>
                            <div class="col-auto mb-2">
                                <a href="~/Bookings/AddBookReservation/@Model.AccomodationDataModel.Id" class="nav-link btn btn-secondary create-new-button">Create Reservation</a>
                            </div>
                            <div class="col-auto mb-2">
                                @if (Model.AccomodationDataModel.AccomodationLogo != "")
                                {
                                    <img class="rounded-circle" style="width: 40px; height: 40px;" src="@Model.AccomodationDataModel.AccomodationLogo" alt="profile">
                                }
                                @if (Model.AccomodationDataModel.AccomodationLogo == "")
                                {
                                    <img class="rounded-circle" style="width: 40px; height: 40px;" alt="profile" src="https://mdbcdn.b-cdn.net/img/Photos/new-templates/bootstrap-chat/ava3.webp">
                                }
                                @if (Model.AccomodationDataModel.AccomodationLogo == null)
                                {
                                    <img class="rounded-circle" style="width: 40px; height: 40px;" alt="profile" src="https://mdbcdn.b-cdn.net/img/Photos/new-templates/bootstrap-chat/ava3.webp">
                                }
                            </div>
                        </div>
                    </div>
                </div>



                <!-- Sales Chart Start -->

                <div class="row g-4">
                    <div class="col-sm-12 col-xl-4">
                        <div class="card-body">
                            <div class="form-group">
                                <label>Accomodation Name</label>
                                <input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.AccomodationName" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Accomodation Email</label>
                                <input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.AccomodationEmail" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Accomodation Description</label>
                                <p style="color: black; background-color: white;">@Model.AccomodationDataModel.AccomodationDescription</p>
                            </div>
                            <div class="form-group">
                                <label>Accomodation Type</label>
                                <input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.AccomodationType" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Check In Time</label>
                                <input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.CheckInTime" readonly type="text" class="form-control readonly-white">

                            </div>
                            <div class="form-group">
                                <label>Check Out Time</label>
                                <input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.CheckOutTime" readonly type="text" class="form-control readonly-white">
                            </div>
                        </div>

                    </div>
                    <div class="col-sm-12 col-xl-4">
                        <div class="card-body">

                            <div class="form-group">
                                <label>Booking Amount</label>
                                <input style="color: black; background-color: white;" value="&#8358;@Model.AccomodationDataModel.BookingAmount.ToString("N2")" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Accomodation Website</label>
                                <input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.AccomodationWebsite" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Accomodation PhoneNo</label>
                                <input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.AccomodationPhoneNo" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Location</label>
                                <input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.Location" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>State</label>
                                <input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.State" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Country</label>
                                <input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.Country" readonly type="text" class="form-control readonly-white">
                            </div>
                        </div>
                    </div>

                    <div class="col-sm-12 col-xl-4">
                        <div class="card-body">

                            <div class="form-group">
                                <label>Locality</label>
                                <input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.Locality" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Postcode</label>
                                <input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.Postcode" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Latitude</label>
                                <input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.Latitude" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Longitude</label>
                                <input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.Longitude" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Rating</label>
                                <input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.Rating" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>CreatedAt</label>
                                <input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.CreatedAt" readonly type="text" class="form-control readonly-white">
                            </div>
                        </div>
                    </div>
                </div>


                <div class="row">
                    <div class="col-md-6 grid-margin stretch-card">
                        <div style="padding-top:20px"></div>

                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr class="text-white">
                                        <th>Accomodation Facilities</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.AccomodationDataModel.AccomodationFacilities!)
                                    {
                                        <tr>
                                            <td> <p><a class="btn btn-outline-success">@item</a></p><span style="padding-left:10px"> </span></td>

                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                    </div>
                    <div class="col-md-6 grid-margin stretch-card">
                        <div style="padding-top:20px"></div>
                       

                        <div class="table-responsive">
                            <h6>Accomodation Images</h6>
                            <div style="padding-top:20px"></div>
                            <div class="custom-carousel">
                                <button class="navCarousel  prev" onclick="moveSlide(-1)">&#10094;</button>

                                <div class="carousel-images">
                                    @for (int i = 0; i < Model.AccomodationDataModel.AccomodationImages!.Count; i++)
                                    {
                                        var item = Model.AccomodationDataModel.AccomodationImages[i];
                                        <img src="@item" class="carousel-image @(i == 0 ? "active" : "")" alt="Accommodation image" />
                                    }
                                </div>

                                <button class="navCarousel  next" onclick="moveSlide(1)">&#10095;</button>
                            </div>

                        </div>

                    </div>
                </div>

              
                    <div class="row">
                        <div style="padding-top:20px"></div>
                        <h6>Time Schedule</h6>
                        <div style="padding-top:20px"></div>
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Day</th>
                                        <th>Start Time</th>
                                        <th>End Time</th>
                                        <th>Closed</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Monday</td>
                                    <td><input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.AccomodationMonday!.HourStart" readonly class="form-control"></td>
                                    <td><input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.AccomodationMonday!.HourEnd" readonly class="form-control"></td>
                                        <td>
                                        @if (@Model.AccomodationDataModel.AccomodationMonday!.IsClosed == true)
                                            {
                                                <button type="button" class="btn btn-warning m-2">Closed</button>

                                            }
                                        @if (Model.AccomodationDataModel.AccomodationMonday!.IsClosed == false)
                                            {
                                                <button type="button" class="btn btn-info m-2">Opened</button>
                                            }<span style="padding-left:10px"> </span>

                                        </td>

                                    </tr>
                                    <tr>
                                        <td>Tuesday</td>
                                    <td><input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.AccomodationTuesday!.HourStart" readonly class="form-control"></td>
                                    <td><input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.AccomodationTuesday!.HourEnd" readonly class="form-control" /></td>
                                        <td>
                                        @if (@Model.AccomodationDataModel.AccomodationTuesday!.IsClosed == true)
                                            {
                                                <button type="button" class="btn btn-warning m-2">Closed</button>

                                            }
                                        @if (Model.AccomodationDataModel.AccomodationTuesday!.IsClosed == false)
                                            {
                                                <button type="button" class="btn btn-info m-2">Opened</button>
                                            }<span style="padding-left:10px"> </span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Wednesday</td>
                                    <td><input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.AccomodationWednesday!.HourStart" readonly class="form-control"></td>
                                    <td><input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.AccomodationWednesday!.HourEnd" readonly class="form-control" /></td>
                                        <td>
                                        @if (@Model.AccomodationDataModel.AccomodationWednesday!.IsClosed == true)
                                            {
                                                <button type="button" class="btn btn-warning m-2">Closed</button>

                                            }
                                        @if (Model.AccomodationDataModel.AccomodationWednesday!.IsClosed == false)
                                            {
                                                <button type="button" class="btn btn-info m-2">Opened</button>
                                            }<span style="padding-left:10px"> </span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Thursday</td>
                                    <td><input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.AccomodationThursday!.HourStart" readonly class="form-control"></td>
                                    <td><input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.AccomodationThursday!.HourEnd" readonly class="form-control" /></td>
                                        <td>
                                        @if (@Model.AccomodationDataModel.AccomodationThursday!.IsClosed == true)
                                            {
                                                <button type="button" class="btn btn-warning m-2">Closed</button>

                                            }
                                        @if (Model.AccomodationDataModel.AccomodationThursday!.IsClosed == false)
                                            {
                                                <button type="button" class="btn btn-info m-2">Opened</button>
                                            }<span style="padding-left:10px"> </span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Friday</td>
                                    <td><input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.AccomodationFriday!.HourStart" readonly class="form-control"></td>
                                    <td><input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.AccomodationFriday!.HourEnd" readonly class="form-control" /></td>
                                        <td>
                                        @if (@Model.AccomodationDataModel.AccomodationFriday!.IsClosed == true)
                                            {
                                                <button type="button" class="btn btn-warning m-2">Closed</button>

                                            }
                                        @if (Model.AccomodationDataModel.AccomodationFriday!.IsClosed == false)
                                            {
                                                <button type="button" class="btn btn-info m-2">Opened</button>
                                            }<span style="padding-left:10px"> </span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Saturday</td>
                                    <td><input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.AccomodationSaturday!.HourStart" readonly class="form-control"></td>
                                    <td><input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.AccomodationSaturday!.HourEnd" readonly class="form-control" /></td>
                                        <td>
                                        @if (@Model.AccomodationDataModel.AccomodationSaturday!.IsClosed == true)
                                            {
                                                <button type="button" class="btn btn-warning m-2">Closed</button>

                                            }
                                        @if (Model.AccomodationDataModel.AccomodationSaturday!.IsClosed == false)
                                            {
                                                <button type="button" class="btn btn-info m-2">Opened</button>
                                            }<span style="padding-left:10px"> </span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Sunday</td>
                                    <td><input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.AccomodationSunday!.HourStart" readonly class="form-control"></td>
                                    <td><input style="color: black; background-color: white;" value="@Model.AccomodationDataModel.AccomodationSunday!.HourEnd" readonly class="form-control" /></td>
                                        <td>
                                        @if (@Model.AccomodationDataModel.AccomodationSunday!.IsClosed == true)
                                            {
                                                <button type="button" class="btn btn-warning m-2">Closed</button>

                                            }
                                        @if (Model.AccomodationDataModel.AccomodationSunday!.IsClosed == false)
                                            {
                                                <button type="button" class="btn btn-info m-2">Opened</button>
                                            }<span style="padding-left:10px"> </span>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>



                <div style="padding-top:20px"></div>
                <h6>Accommodation Reservation</h6>
                <div style="padding-top:20px"></div>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th> Accomodation Name </th>
                                <th> Ticket Num </th>
                                <th> Maximum No Of Guest </th>
                                <th> Room Number </th>
                                <th> Room Type </th>
                                <th> RoomPrice </th>
                                <th> Accomodation Locality </th>
                                <th> Date </th>
                                <th> Details </th>
                                <th> Delete </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.BookAccomodationReservatioModel!.Take(5))
                            {
                                <tr>
                                    <td> @item.AccomodationName </td>
                                    <td> @item.TicketNum </td>
                                    <td> @item.MaximumNoOfGuest </td>
                                    <td> @item.RoomNumber </td>
                                    <td> @item.RoomType </td>
                                    <td> &#8358;@item.RoomPrice.ToString("N2") </td>
                                    <td> @item.AccomodationLocality </td>
                                    <td>@item.CreatedAt</td>
                                    <td><a href="@Url.Action("AccomodationReservationDetails", "Bookings", new { id = item!.Id })" class="btn btn-outline-info">View</a><td>
                                    <td><a href="@Url.Action("DeleteBookReservation", "Bookings", new { id = item!.Id })" class="btn btn-danger">Delete</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div style="padding-top:20px"></div>
                    <p><a href="@Url.Action("AllAccomodationReservationList", "Bookings", new { id = Model.AccomodationDataModel!.Id })" class="btn btn-danger">View All Reservation</a></p>
                </div>

                  <div style="padding-top:20px"></div>
                <h6>Customer Reservations</h6>
                <div style="padding-top:20px"></div>
                <div class="table-responsive">
                    <table class="table">
                            <thead>
                                <tr>
                                    <th> Accomodation Name </th>
                                    <th> Customer Name </th>
                                    <th> Ticket Num </th>
                                    <th> Reservation Start Date </th>
                                    <th> Reservation End Date  </th>
                                    <th> Total Cost </th>
                                    <th> No Of Days </th>
                                    <th> Room Number </th>
                                    <th> Date </th>
                                    <th> Details </th>
                                    <th> Delete </th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var item in Model.CustomerBookedReservation!.Take(5))
                            {
                                        <tr>
                                            <td> @item.AccomodationName </td>
                                            <td> @item.CustomerName </td>
                                            <td> @item.TicketNum </td>
                                            <td> @item.ReservationStartDate </td>
                                            <td> @item.ReservationEndDate  </td>
                                            <td> &#8358;@item.TotalCost.ToString("N2") </td>
                                            <td> @item.NoOfDays </td>
                                            <td>
                                                <div class="badge badge-outline-success">@item.RoomNumber</div>
                                            </td>
                                            <td>@item.CreatedAt</td>
                                            <td><a href="@Url.Action("CustomerReservationDetails", "Bookings", new { id = item!.Id })" class="btn btn-outline-info">View</a><td>
                                    <td><a href="@Url.Action("DeleteCustomerReservation", "Bookings", new { id = item!.Id })" class="btn btn-danger">Delete</a></td>
                                        </tr>
                            }
                            </tbody>
                        </table>
                    <div style="padding-top:20px"></div>
                    <p><a href="@Url.Action("CustomerReservationList", "Bookings", new { id = Model.AccomodationDataModel!.Id })" class="btn btn-danger">View All Customers</a></p>
                </div>

                <div style="padding-top:20px"></div>
                <h6>Users Review</h6>
                <div style="padding-top:20px"></div>

                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>User Name</th>
                                <th>Rating Num</th>
                                <th>Review Message</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.AccomodationDataModel.AccomodationReviewModels!)
                            {
                                <tr>

                                    <td>@item.UserName</td>
                                    <td>
                                        <span class="rating-stars">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= @item.RatingNum)
                                                {
                                                    <span class="star filled">★</span>
                                                }
                                                else
                                                {
                                                    <span class="star">★</span>
                                                }
                                            }
                                        </span>
                                    </td>
                                    <td>@item.ReviewMessage</td>
                                    <td>@item!.CreatedAt</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>


            </div>

        </div>
    </div>

</div>

