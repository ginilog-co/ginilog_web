@model Ginilog_AdminWeb.Models.BookingsModel.AllBookedReservationModel

@{
    ViewData["Title"] = "AccomodationReservationDetails";
    Layout = "~/Views/Shared/_NewLayout.cshtml";
}

<!-- Delete Modal -->
<div id="deleteModal" class="custom-modal">
    <div class="custom-modal-content">
        <div class="custom-modal-header">
            <h5 style="color:black" class="modal-title">Confirm Delete</h5>
            <span style="color:black" class="custom-modal-close" onclick="closeModal()">&times;</span>
        </div>
        <div class="custom-modal-body">
            <p style="color:black">   Are you sure you want to delete this Item?</p>

        </div>
        <div class="custom-modal-footer">
            <button onclick="closeModal()" class="btn-secondary">Cancel</button>
            <a href="@Url.Action("DeleteBookReservationConfirm", "Bookings", new { id = Model!.BookAccomodationReservatioModel!.Id })" class="btn-danger">Delete</a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12 grid-margin">
        <div class="card">
            <div class="card-body">


                <div class="row px-0 mx-0">
                    <div class="col-12 grid-margin px-0">
                        <div class="d-flex justify-content-end gap-2 px-0">

                            <div class="col-auto mb-2">
                                <button class="nav-link btn btn-danger create-new-button" onclick="openModal()">Delete</button>
                            </div>
                            <div class="col-auto mb-2">
                                <a href="~/Home/ManagerDetails/@Model.BookAccomodationReservatioModel.AdminId" class="nav-link btn btn-primary create-new-button">View Manager</a>
                            </div>
                            <div class="col-auto mb-2">
                                <a href="~/Bookings/AddCustomerReservation/@Model.BookAccomodationReservatioModel.Id" class="nav-link btn btn-secondary create-new-button">Book Reservation</a>
                            </div>
                            <div class="col-auto mb-2">
                                @if (Model.BookAccomodationReservatioModel.AccomodationImage != "")
                                {
                                    <img class="rounded-circle" style="width: 40px; height: 40px;" src="@Model.BookAccomodationReservatioModel.AccomodationImage" alt="profile">
                                }
                                @if (Model.BookAccomodationReservatioModel.AccomodationImage == "")
                                {
                                    <img class="rounded-circle" style="width: 40px; height: 40px;" alt="profile" src="https://mdbcdn.b-cdn.net/img/Photos/new-templates/bootstrap-chat/ava3.webp">
                                }
                                @if (Model.BookAccomodationReservatioModel.AccomodationImage == null)
                                {
                                    <img class="rounded-circle" style="width: 40px; height: 40px;" alt="profile" src="https://mdbcdn.b-cdn.net/img/Photos/new-templates/bootstrap-chat/ava3.webp">
                                }
                            </div>
                        </div>
                    </div>
                </div>



                <!-- Sales Chart Start -->

                <div class="row g-4">
                    <div class="col-sm-12 col-xl-4">
                        <div class="card-body">
                            <div class="form-group">
                                <label>Accomodation Name</label>
                                <input style="color: black; background-color: white;" value="@Model.BookAccomodationReservatioModel.AccomodationName" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Accomodation Type</label>
                                <input style="color: black; background-color: white;" value="@Model.BookAccomodationReservatioModel.AccomodationType" readonly type="text" class="form-control readonly-white">
                            </div>

                   
                            <div class="form-group">
                                <label>Ticket Num</label>
                                <input style="color: black; background-color: white;" value="@Model.BookAccomodationReservatioModel.TicketNum" readonly type="text" class="form-control readonly-white">

                            </div>
                            <div class="form-group">
                                <label>Is Booked</label>
                                <input style="color: black; background-color: white;" value="@Model.BookAccomodationReservatioModel.IsBooked" readonly type="text" class="form-control readonly-white">
                            </div>
                        </div>

                    </div>
                    <div class="col-sm-12 col-xl-4">
                        <div class="card-body">

                            <div class="form-group">
                                <label>Room Price</label>
                                <input style="color: black; background-color: white;" value="&#8358;@Model.BookAccomodationReservatioModel.RoomPrice.ToString("N2")" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Accomodation Locality</label>
                                <input style="color: black; background-color: white;" value="@Model.BookAccomodationReservatioModel.AccomodationLocality" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Accomodation State</label>
                                <input style="color: black; background-color: white;" value="@Model.BookAccomodationReservatioModel.AccomodationState" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Room Number</label>
                                <input style="color: black; background-color: white;" value="@Model.BookAccomodationReservatioModel.RoomNumber" readonly type="text" class="form-control readonly-white">
                            </div>
                        </div>
                    </div>

                    <div class="col-sm-12 col-xl-4">
                        <div class="card-body">

                          
                            <div class="form-group">
                                <label>Room Type</label>
                                <input style="color: black; background-color: white;" value="@Model.BookAccomodationReservatioModel.RoomType" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Maximum No Of Guest</label>
                                <input style="color: black; background-color: white;" value="@Model.BookAccomodationReservatioModel.MaximumNoOfGuest" readonly type="text" class="form-control readonly-white">
                            </div>
                           
                            <div class="form-group">
                                <label>CreatedAt</label>
                                <input style="color: black; background-color: white;" value="@Model.BookAccomodationReservatioModel.CreatedAt" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>UpdatedAt</label>
                                <input style="color: black; background-color: white;" value="@Model.BookAccomodationReservatioModel.UpdateddAt" readonly type="text" class="form-control readonly-white">
                            </div>
                        </div>
                    </div>
                </div>


                <div class="row">
                    <div class="col-md-6 grid-margin stretch-card">
                        <div style="padding-top:20px"></div>

                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr class="text-white">
                                        <th>Accomodation Facilities</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.BookAccomodationReservatioModel.RoomFeatures!)
                                    {
                                        <tr>
                                            <td> <p><a class="btn btn-outline-success">@item</a></p><span style="padding-left:10px"> </span></td>

                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                    </div>
                    <div class="col-md-6 grid-margin stretch-card">
                        <div style="padding-top:20px"></div>


                        <div class="table-responsive">
                            <h6>Room Images</h6>
                            <div style="padding-top:20px"></div>
                            <div class="custom-carousel">
                                <button class="navCarousel  prev" onclick="moveSlide(-1)">&#10094;</button>

                                <div class="carousel-images">
                                    @for (int i = 0; i < Model.BookAccomodationReservatioModel.RoomImages!.Count; i++)
                                    {
                                        var item = Model.BookAccomodationReservatioModel.RoomImages[i];
                                        <img src="@item" class="carousel-image @(i == 0 ? "active" : "")" alt="Accommodation image" />
                                    }
                                </div>

                                <button class="navCarousel  next" onclick="moveSlide(1)">&#10095;</button>
                            </div>

                        </div>

                    </div>
                </div>


           
             

                <div style="padding-top:20px"></div>
                <h6>Customer Reservations</h6>
                <div style="padding-top:20px"></div>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th> Accomodation Name </th>
                                <th> Customer Name </th>
                                <th> Ticket Num </th>
                                <th> Reservation Start Date </th>
                                <th> Reservation End Date  </th>
                                <th> Total Cost </th>
                                <th> No Of Days </th>
                                <th> Room Number </th>
                                <th> Date </th>
                                <th> Details </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.CustomerBookedReservation!.Take(5))
                            {
                                <tr>
                                    <td> @item.AccomodationName </td>
                                    <td> @item.CustomerName </td>
                                    <td> @item.TicketNum </td>
                                    <td> @item.ReservationStartDate </td>
                                    <td> @item.ReservationEndDate  </td>
                                    <td> &#8358;@item.TotalCost.ToString("N2") </td>
                                    <td> @item.NoOfDays </td>
                                    <td>
                                        <div class="badge badge-outline-success">@item.RoomNumber</div>
                                    </td>
                                    <th>@item.CreatedAt</th>
                                    <td><a href="@Url.Action("CustomerReservationDetails", "Home", new { id = item!.Id })" class="btn btn-outline-info">View</a>
                                    <td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div style="padding-top:20px"></div>
                    <p><a href="@Url.Action("CustomerReservationList", "Bookings", new { id = Model.BookAccomodationReservatioModel!.Id })" class="btn btn-danger">View All Customers</a></p>
                </div>

            </div>

        </div>
    </div>

</div>


