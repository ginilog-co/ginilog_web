                </div>

                 <div class="table-responsive">
                    <h6>Order Images</h6>
                            <div style="padding-top:20px"></div>
                            <div class="custom-carousel">
                                <button class="navCarousel  prev" onclick="moveSlide(-1)">&#10094;</button>

                                <div class="carousel-images">
                            @for (int i = 0; i < Model.OrderModelData!.PackageImageLists!.Count; i++)
                            {
                                var item = Model.OrderModelData!.PackageImageLists[i];
                                <a target="_blank" href="@item"> <img src="@item" class="carousel-image @(i == 0 ? "active" : "")" alt="Accommodation image" /></a>
                            }
                                </div>

                                <button class="navCarousel  next" onclick="moveSlide(1)">&#10095;</button>
                            </div>

                        </div>

                <!--Track Order-->


                <div>
                    <div style="padding-top:20px"></div>
                    <h6>Track Order Flow</h6>
                    <div style="padding-top:20px"></div>
                    @if (Model.OrderModelData!.OrderStatus == "Open" || Model.OrderModelData!.OrderStatus == "Accepted" ||
                    Model.OrderModelData!.OrderStatus == "Picked" || Model.OrderModelData!.OrderStatus == "Ongoing" ||
                    Model.OrderModelData!.OrderStatus == "Completed" || Model.OrderModelData!.OrderStatus == "Delivered" || Model.OrderModelData!.OrderStatus == "Closed")
                    {
                        <p class="text-white bg-secondary p-2 rounded">
                            A Customer has opened an order and is awaiting processing.
                        </p>
                        <p class="text-center" style="font-size: 2rem;">&#x25BC;</p> <!-- Centered, larger arrow -->
                        @if (Model.OrderModelData!.OrderStatus == "Open")
                        {
                            <p class="text-center" style="font-size: 2rem;">Time: @ViewBag.Time</p> <!-- Centered, larger arrow -->
                        }

                    }

                    @if (Model.OrderModelData!.OrderStatus == "Accepted" ||
                    Model.OrderModelData!.OrderStatus == "Picked" || Model.OrderModelData!.OrderStatus == "Ongoing" ||
                    Model.OrderModelData!.OrderStatus == "Completed" || Model.OrderModelData!.OrderStatus == "Delivered" || Model.OrderModelData!.OrderStatus == "Closed")
                    {
                        <p class="text-success p-2 rounded">
                            Rider has accepted the order and it is being prepared.
                        </p>
                        <p class="text-center" style="font-size: 2rem;">&#x25BC;</p> <!-- Centered, larger arrow -->
                        @if (Model.OrderModelData!.OrderStatus == "Accepted")
                        {
                            <p class="text-center" style="font-size: 2rem;">Time: @ViewBag.Time</p> <!-- Centered, larger arrow -->
                        }
                    }

                    @if (Model.OrderModelData!.OrderStatus == "Picked" || Model.OrderModelData!.OrderStatus == "Ongoing" ||
                    Model.OrderModelData!.OrderStatus == "Completed" || Model.OrderModelData!.OrderStatus == "Delivered" || Model.OrderModelData!.OrderStatus == "Closed")
                    {
                        <p class="text-warning p-2 rounded">
                            Your order has been picked and is heading to the gas station.
                        </p>
                        <p class="text-center" style="font-size: 2rem;">&#x25BC;</p> <!-- Centered, larger arrow -->
                        @if (Model.OrderModelData!.OrderStatus == "Picked")
                        {
                            <p class="text-center" style="font-size: 2rem;">Time: @ViewBag.Time</p> <!-- Centered, larger arrow -->
                        }
                    }

                    @if (Model.OrderModelData!.OrderStatus == "Ongoing" || Model.OrderModelData!.OrderStatus == "Completed" || Model.OrderModelData!.OrderStatus == "Delivered" ||
                    Model.OrderModelData!.OrderStatus == "Closed")
                    {
                        <p class="text-primary p-2 rounded">
                            The order is on the way!
                        </p>
                        <p class="text-center" style="font-size: 2rem;">&#x25BC;</p> <!-- Centered, larger arrow -->
                        @if (Model.OrderModelData!.OrderStatus == "Ongoing")
                        {
                            <p class="text-center" style="font-size: 2rem;">Time: @ViewBag.Time</p> <!-- Centered, larger arrow -->
                        }
                    }

                    @if (Model.OrderModelData!.OrderStatus == "Completed" || Model.OrderModelData!.OrderStatus == "Delivered" ||
                    Model.OrderModelData!.OrderStatus == "Closed")
                    {
                        <p class="text-info p-2 rounded">
                            This order has been successfully completed.
                        </p>
                        <p class="text-center" style="font-size: 2rem;">&#x25BC;</p> <!-- Centered, larger arrow -->
                        @if (Model.OrderModelData!.OrderStatus == "Completed")
                        {
                            <p class="text-center" style="font-size: 2rem;">Time: @ViewBag.Time</p> <!-- Centered, larger arrow -->
                        }
                    }

                    @if (Model.OrderModelData!.OrderStatus == "Delivered" || Model.OrderModelData!.OrderStatus == "Closed")
                    {
                        <p class="text-warning p-2 rounded" style="background-color: wheat;">
                            This order is now delivered.
                        </p>
                        <p class="text-center" style="font-size: 2rem;">&#x25BC;</p> <!-- Centered, larger arrow -->
                        @if (Model.OrderModelData!.OrderStatus == "Delivered")
                        {
                            <p class="text-center" style="font-size: 2rem;">Time: @ViewBag.Time</p>
                        }
                    }

                    @if (Model.OrderModelData!.OrderStatus == "Closed")
                    {
                        <p class="text-muted p-2 rounded">This order is now closed. </p>
                        @if (Model.OrderModelData!.OrderStatus == "Closed")
                        {
                            <p class="text-center" style="font-size: 2rem;">Time: @ViewBag.Time</p>
                        }
                    }
                    @if (Model.OrderModelData!.OrderStatus == "Rejected")
                    {
                        <p class="text-danger p-2 rounded">
                            Rejected state.
                        </p>
                        @if (Model.OrderModelData!.OrderStatus == "Rejected")
                        {
                            <p class="text-center" style="font-size: 2rem;">Time: @ViewBag.Time</p>
                        }
                    }



                    @{
                        var currentStatus = CultureInfo.CurrentCulture.TextInfo.ToTitleCase(Model.OrderModelData!.OrderStatus!.ToLower());
                    }

                    @foreach (var status in Model.OrderModelData!.OrderDeliveryFlows!)
                    {
                        var statusName = CultureInfo.CurrentCulture.TextInfo.ToTitleCase(status.OrderStatus!.ToLower());
                        var statusDate = status.UpdatedAt.ToLocalTime().ToString("ddd, MMM d hh:mm tt");
                        var isLast = status == Model.OrderModelData!.OrderDeliveryFlows.Last();
                        var iconClass = statusName == currentStatus ? "icon-grey" : "icon-green";
                        var textColorClass = statusName == currentStatus ? "text-grey" : "text-green";
                        <div class="track-flow-row">
                            <div class="icon-column">
                                <i class="@(statusName == currentStatus ? "far fa-square" : "far fa-check-square") @iconClass"></i>
                                @if (!isLast)
                                {
                                    <div class="dashed-line"></div>
                                }
                            </div>
                            <div class="content-column">
                                <p class="status-title @textColorClass">Package Status: @statusName</p>
                                <p class="status-date">@statusDate</p>
                                <p class="status-location text-truncate">@status.CurrentLocation</p>
                            </div>
                        </div>
                    }

                </div>
              </div>

          </div>
      </div>

</div>