                                <input style="color: black; background-color: white;" value="@Model.OrderModelData!.SenderEmail" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Sender Address</label>
                                <input style="color: black; background-color: white;" value="@Model.OrderModelData!.SenderAddress" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Sender State</label>
                                <input style="color: black; background-color: white;" value="@Model.OrderModelData!.SenderState" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Sender Country</label>
                                <input style="color: black; background-color: white;" value="@Model.OrderModelData!.SenderCountry" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Sender Locality</label>
                                <input style="color: black; background-color: white;" value="@Model.OrderModelData!.SenderLocality" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Sender Postal Code</label>
                                <input style="color: black; background-color: white;" value="@Model.OrderModelData!.SenderPostalCode" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Sender Latitude</label>
                                <input style="color: black; background-color: white;" value="@Model.OrderModelData!.SenderLatitude" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Sender Longitude</label>
                                <input style="color: black; background-color: white;" value="@Model.OrderModelData!.SenderLongitude" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Reciever Name</label>
                                <input style="color: black; background-color: white;" value="@Model.OrderModelData!.RecieverName" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Reciever PhoneNo</label>
                                <input style="color: black; background-color: white;" value="@Model.OrderModelData!.RecieverPhoneNo" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Reciever Email</label>
                                <input style="color: black; background-color: white;" value="@Model.OrderModelData!.RecieverEmail" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Reciever Addressl</label>
                                <input style="color: black; background-color: white;" value="@Model.OrderModelData!.RecieverAddress" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
