@using System.Globalization
@model Ginilog_AdminWeb.Models.LogisticsModel.OrdersDetailsDataModel

@{
    ViewData["Title"] = "OrderDetails";
    Layout = "~/Views/Shared/_NewLayout.cshtml";
}


<!--Update Expected Delivery Time -->
<div id="fourthModal" class="custom-modal">
    <div class="custom-modal-content">
        <div class="custom-modal-header">
            <h5 style="color:black" class="modal-title">Update Order Status</h5>
            <span style="color:black" class="custom-modal-close" onclick="closeFourthModal()">&times;</span>
        </div>
        <div class="custom-modal-body">

            <form asp-action="UpdateOrderStatus" method="post">

                <div class="form-group">
                    <label>Update Order Status *</label>
                    <input asp-for="UpdateOrderStatus!.Id!" hidden value="@ViewBag.Id" class="form-control p_input" placeholder="Shipping Cost">
                    <select asp-for="UpdateOrderStatus!.OrderStatus" class="form-control p_input" aria-label="Floating label select example">
                        <option selected>Choose Order Status</option>
                        <option value="Picked">Picked</option>
                        <option value="Booked">Booked</option>
                        <option value="InTransit">InTransit</option>
                        <option value="Delivered">Delivered</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                    <span asp-validation-for="UpdateOrderStatus!.OrderStatus" class="text-danger"></span>
                </div>

               

                <button type="submit" class="btn btn-primary py-3 w-100 mb-4">Send</button>
            </form>

        </div>
        <div class="custom-modal-footer">
            <button onclick="closeFourthModal()" class="btn-secondary">Cancel</button>
        </div>
    </div>
</div>

<!--Update Expected Delivery Time -->
<div id="thirdModal" class="custom-modal">
    <div class="custom-modal-content">
        <div class="custom-modal-header">
            <h5 style="color:black" class="modal-title">Update Expected Delivery Time</h5>
            <span style="color:black" class="custom-modal-close" onclick="closeThirdModal()">&times;</span>
        </div>
        <div class="custom-modal-body">

            <form asp-action="UpdateExpectedDeliveryTime" method="post">
                <div class="form-group">
                    <label>Expected Delivery Time</label>
                    <input asp-for="UpdateExpectedDeliveryTime!.Id!" hidden value="@ViewBag.Id" class="form-control p_input" placeholder="Shipping Cost">
                    <input asp-for="UpdateExpectedDeliveryTime!.ExpectedDeliveryTime!" type="date" class="form-control p_input" placeholder="Expected Delivery Time">

                </div>

                <button type="submit" class="btn btn-primary py-3 w-100 mb-4">Send</button>
            </form>

        </div>
        <div class="custom-modal-footer">
            <button onclick="closeThirdModal()" class="btn-secondary">Cancel</button>
        </div>
    </div>
</div>

<!--Update Shipping Cost-->
<div id="secondModal" class="custom-modal">
    <div class="custom-modal-content">
        <div class="custom-modal-header">
            <h5 style="color:black" class="modal-title">Update Shipping Cost</h5>
            <span style="color:black" class="custom-modal-close" onclick="closeSecondModal()">&times;</span>
        </div>
        <div class="custom-modal-body">

            <form asp-action="UpdateShippingCost" method="post">
                <div class="form-group">
                    <label>Shipping Cost</label>
                    <input asp-for="UpdateShippingCost!.Id!" hidden value="@ViewBag.Id" class="form-control p_input" placeholder="Shipping Cost">
                    <input asp-for="UpdateShippingCost!.ShippingCost!" type="number" class="form-control p_input" placeholder="Shipping Cost">

                </div>
                <div class="form-group">
                    <label>Vat</label>
                    <input asp-for="UpdateShippingCost!.VatCost" type="number" class="form-control p_input" placeholder="Vat">

                </div>
               
               

                <button type="submit" class="btn btn-primary py-3 w-100 mb-4">Send</button>
            </form>

        </div>
        <div class="custom-modal-footer">
            <button onclick="closeSecondModal()" class="btn-secondary">Cancel</button>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div id="deleteModal" class="custom-modal">
    <div class="custom-modal-content">
        <div class="custom-modal-header">
            <h5 style="color:black" class="modal-title">Confirm Delete</h5>
            <span style="color:black" class="custom-modal-close" onclick="closeModal()">&times;</span>
        </div>
        <div class="custom-modal-body">
            <p style="color:black">   Are you sure you want to delete this Item?</p>

        </div>
        <div class="custom-modal-footer">
            <button onclick="closeModal()" class="btn-secondary">Cancel</button>
            <a href="@Url.Action("DeleteOrderConfirm", "Logistics", new { id = Model.OrderModelData!.Id })" class="btn-danger">Delete</a>
        </div>
    </div>
</div>


 
<div class="row">
    <div class="col-12 grid-margin">
        <div class="card">
            <div class="card-body">


                <div class="row px-0 mx-0">
                    <div class="col-12 grid-margin px-0">
                        <div class="d-flex justify-content-end gap-2 px-0">
                           
                            <div class="col-auto mb-2">
                                <button class="nav-link btn btn-danger create-new-button" onclick="openModal()">Delete</button>
                            </div>

                            <div class="col-auto mb-2">
                                <a class="nav-link btn btn-primary  create-new-button">@Model.OrderModelData!.OrderStatus</a>
                            </div>
                            <div class="col-auto mb-2">
                                <a class="nav-link btn btn-secondary  create-new-button">@Model.OrderModelData!.UserType User</a>
                            </div>
                           @if(Model.OrderModelData!.ShippingCost<=0)
                           {
                                <div class="col-auto mb-2">
                                    <button onclick="openSecondModal()" class="nav-link btn btn-secondary create-new-button">Add Shipping Cost</button>
                                </div>
                           }
                           @if(Model.OrderModelData!.PaymentStatus==true)
                           {
                                @if (Model.OrderModelData!.ExpectedDeliveryTime == "")
                                {
                                    <div class="col-auto mb-2">
                                        <button onclick="openThirdModal()" class="nav-link btn btn-secondary create-new-button">Add Delivery Time</button>
                                    </div>
                                }
                                @if (Model.OrderModelData!.OrderStatus != "Delivered")
                                {
                                    <div class="col-auto mb-2">
                                        <button onclick="openFourthModal()" class="nav-link btn btn-outline-primary create-new-button">Update OrderStatus</button>
                                    </div>
                                }
                              
                                <div class="col-auto mb-2">
                                    <button  class="nav-link btn btn-secondary create-new-button">Paid</button>
                                </div>
                           }
                           
                        </div>
                    </div>
                </div>



