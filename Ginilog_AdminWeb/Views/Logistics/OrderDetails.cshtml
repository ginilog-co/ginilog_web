                                <input style="color: black; background-color: white;" value="@Model.OrderModelData!.RecieverState" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Reciever Country</label>
                                <input style="color: black; background-color: white;" value="@Model.OrderModelData!.RecieverCountry" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Reciever Locality</label>
                                <input style="color: black; background-color: white;" value="@Model.OrderModelData!.RecieverLocality" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Reciever PostalCode</label>
                                <input style="color: black; background-color: white;" value="@Model.OrderModelData!.RecieverPostalCode" readonly type="text" class="form-control readonly-white">
                            </div>
                           
                            <div class="form-group">
                                <label>Reciever Latitude</label>
                                <input style="color: black; background-color: white;" value="@Model.OrderModelData!.RecieverLatitude" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Reciever Longitude</label>
                                <input style="color: black; background-color: white;" value="@Model.OrderModelData!.RecieverLongitude" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Company Name</label>
                                <input style="color: black; background-color: white;" value="@Model.OrderModelData!.CompanyName" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Company PhoneNo</label>
                                <input style="color: black; background-color: white;" value="@Model.OrderModelData!.CompanyPhoneNo" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Company Email</label>
                                <input style="color: black; background-color: white;" value="@Model.OrderModelData!.CompanyEmail" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Company Address</label>
                                <input style="color: black; background-color: white;" value="@Model.OrderModelData!.CompanyAddress" readonly type="text" class="form-control readonly-white">
                            </div>
