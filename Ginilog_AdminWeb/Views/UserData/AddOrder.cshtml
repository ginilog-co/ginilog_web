@model Ginilog_AdminWeb.Models.LogisticsModel.AddOrder

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Admin - Ginilog Admin Panel</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="" name="keywords">
    <meta content="" name="description">
    <!-- plugins:css -->
    <link rel="stylesheet" href="~/new/assets/vendors/mdi/css/materialdesignicons.min.css">
    <link rel="stylesheet" href="~/new/assets/vendors/css/vendor.bundle.base.css">
    <!-- endinject -->
    <!-- Plugin css for this page -->
    <link rel="stylesheet" href="~/new/assets/vendors/jvectormap/jquery-jvectormap.css">
    <link rel="stylesheet" href="~/new/assets/vendors/flag-icon-css/css/flag-icon.min.css">
    <link rel="stylesheet" href="~/new/assets/vendors/owl-carousel-2/owl.carousel.min.css">
    <link rel="stylesheet" href="~/new/assets/vendors/owl-carousel-2/owl.theme.default.min.css">
    <!-- End plugin css for this page -->
    <!-- inject:css -->
    <!-- endinject -->
    <!-- Layout styles -->
    <link rel="stylesheet" href="~/new/assets/css/style.css">
    <!-- End layout styles -->
    <link rel="shortcut icon" href="~/new/assets/images/favicon1.png" />
     <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyCuU7j9XnHs31-I6NE7cz_SxOw3lzScFuo&libraries=places"></script>
    <script>
            // your initAutocomplete function goes here
              function initSenderAutocomplete() {
                const autocompleteInput = document.getElementById('senderData');
                const autocomplete = new google.maps.places.Autocomplete(autocompleteInput, {
                    types: ['geocode']
                });

                 autocomplete.setFields(['place_id']);

              autocomplete.addListener('place_changed', function () {
             const place = autocomplete.getPlace();
              const placeId = place.place_id;

            // Set hidden input value
            document.getElementById('SenderPlaceId').value = placeId;
        });
            }

            function initRecieverAutocomplete() {
                     const autocompleteInput = document.getElementById('recieverData');
                     const autocomplete = new google.maps.places.Autocomplete(autocompleteInput, {
                         types: ['geocode']
                     });

                     autocomplete.setFields(['place_id']);

                autocomplete.addListener('place_changed', function () {
               const place = autocomplete.getPlace();
               const placeId = place.place_id;

            // Set hidden input value
                document.getElementById('RecieverPlaceId').value = placeId;
        });
                 }



            google.maps.event.addDomListener(window, 'load', initSenderAutocomplete);
            google.maps.event.addDomListener(window, 'load', initRecieverAutocomplete);
    </script>
</head>
<body>




    <!-- Spinner End -->
    <div class="content-wrapper">

        <div style="padding-top:20px"></div>
        <p>
            <a asp-action="AllLogCompanyList" class="btn btn-outline-primarym-2">Back to List</a>
        </p>
        <h6 class="mb-4">Add User Order</h6>
        <form asp-action="AddOrder" enctype="multipart/form-data" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label>Company List</label>
                <select id="companySelect" asp-for="CompanyId" asp-items="ViewBag.Companies" class="form-control p_input" aria-label="Floating label select example">
                    <option value="">-- Select Company --</option>
                </select>
                <span asp-validation-for="CompanyId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Package Image List</label>
                <input id="ImageList" asp-for="ImageList" type="file" accept="image/*" multiple class="form-control p_input"
                       placeholder="Image List">
                <span asp-validation-for="ImageList" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Item Name</label>
                <input hidden asp-for="UserId" value="@ViewBag.UserId" type="text" class="form-control p_input" placeholder="Accomodation Name">
                <input asp-for="ItemName" type="text" class="form-control p_input" placeholder="Item Name">
                <span asp-validation-for="ItemName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Item Model Number</label>
                <input asp-for="ItemModelNumber" type="text" class="form-control p_input" placeholder="Item Model Number">
                <span asp-validation-for="ItemModelNumber" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label>Item Cost</label>
                <input asp-for="ItemCost" type="number" class="form-control p_input" placeholder="Item Cost">
                <span asp-validation-for="ItemCost" class="text-danger"></span>
                <span class="text-danger">@ViewBag.UserError</span>
            </div>
            <div class="form-group">
                <label>Item Quantity</label>
                <input asp-for="ItemQuantity" type="number" class="form-control p_input" placeholder="Item Quantity">
                <span asp-validation-for="ItemQuantity" class="text-danger"></span>
                <span class="text-danger">@ViewBag.UserError</span>
            </div>
            <div class="form-group">
                <label>Item Weight</label>
                <input asp-for="ItemCost" type="number" class="form-control p_input" placeholder="Item Weight">
                <span asp-validation-for="ItemWeight" class="text-danger"></span>
                <span class="text-danger">@ViewBag.UserError</span>
            </div>


            <div class="form-group">
                <label>Choose Package Type</label>
                <select asp-for="PackageType" class="form-control p_input" aria-label="Floating label select example">
                    <option selected>Choose Package Type</option>
                    <option value="Electronics">Electronics</option>
                    <option value="Documents">Documents</option>
                    <option value="Clothing">Clothing</option>
                    <option value="Foodstuff">Foodstuff</option>
                    <option value="Others">Others</option>
                </select>

                <span asp-validation-for="PackageType" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label>Choose Rider Type</label>
                <select asp-for="RiderType" class="form-control p_input" aria-label="Floating label select example">
                    <option selected>Choose Rider Type</option>
                    <option value="Motocycle">Motocycle</option>
                    <option value="Van">Van</option>
                    <option value="Truck">Truck</option>
                    <option value="Others">Others</option>
                </select>

                <span asp-validation-for="RiderType" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label>Choose Shipping Type</label>
                <select asp-for="ShippingType" class="form-control p_input" aria-label="Floating label select example">
                    <option selected>Choose Shipping Type</option>
                    <option value="Same State">Same State</option>
                    <option value="Inter State">Inter State</option>
                    <option value="International">International</option>
                    <option value="Charter">Charter</option>
                </select>

                <span asp-validation-for="ShippingType" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label>Item Description</label>
                <textarea asp-for="ItemDescription" class="form-control p_input" placeholder="Item Description"></textarea>
                <span asp-validation-for="ItemDescription" class="text-danger"></span>
            </div>
            <h2>Sender Info</h2>
            <div class="form-group">
                <label>Sender Name</label>
                <input asp-for="SenderName" type="text" class="form-control p_input" placeholder="Sender Name">
                <span asp-validation-for="SenderName" class="text-danger"></span>
                <span class="text-danger">@ViewBag.UserError</span>
            </div>
            <div class="form-group">
                <label>Sender PhoneNo</label>
                <input asp-for="SenderPhoneNo" type="tel" maxlength="11" pattern="\d{10,11}" class="form-control p_input" placeholder="Sender PhoneNo">
                <span asp-validation-for="SenderPhoneNo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label>Sender Email</label>
                <input asp-for="SenderEmail" type="email" class="form-control p_input" placeholder="Sender Email">
                <span asp-validation-for="SenderEmail" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Sender Address</label>
                <input id="senderData" type="text" class="form-control p_input" placeholder="Start typing an address...">
                <!-- Hidden fields to hold extracted data -->
                <input type="hidden" asp-for="SenderAddress" id="SenderPlaceId" />
                <span asp-validation-for="SenderAddress" class="text-danger"></span>
            </div>
            <h2>Receiver Info</h2>
            <div class="form-group">
                <label>Reciever Name</label>
                <input asp-for="RecieverName" type="text" class="form-control p_input" placeholder="Reciever Name">
                <span asp-validation-for="RecieverName" class="text-danger"></span>
                <span class="text-danger">@ViewBag.UserError</span>
            </div>
            <div class="form-group">
                <label>Reciever PhoneNo</label>
                <input asp-for="RecieverPhoneNo" type="tel" maxlength="11" pattern="\d{10,11}" class="form-control p_input" placeholder="Reciever PhoneNo">
                <span asp-validation-for="RecieverPhoneNo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label>Reciever Email</label>
                <input asp-for="RecieverEmail" type="email" class="form-control p_input" placeholder="Reciever Email">
                <span asp-validation-for="RecieverEmail" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Reciever Address</label>
                <input id="recieverData" type="text" class="form-control p_input" placeholder="Start typing an address...">
                <!-- Hidden fields to hold extracted data -->
                <input type="hidden" asp-for="RecieverAddress" id="RecieverPlaceId" />
                <span asp-validation-for="RecieverAddress" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label>Shipping Cost</label>
                <input asp-for="ShippingCost" type="number" class="form-control p_input" placeholder="Shipping Cost">
                <span asp-validation-for="ShippingCost" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label>Vat Cost</label>
                <input asp-for="VatCost" type="number" class="form-control p_input" placeholder="Vat Cost">
                <span asp-validation-for="VatCost" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label>Expected DeliveryTime</label>
                <input asp-for="ExpectedDeliveryTime" type="date" class="form-control p_input" placeholder="Expected Delivery Time">
                <span asp-validation-for="ExpectedDeliveryTime" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Choose Payment Channel</label>
                <select asp-for="PaymentChannel" class="form-control p_input" aria-label="Floating label select example">
                    <option selected>Choose Payment Channel</option>
                    <option value="Paystack">Paystack</option>
                    <option value="Flutterwave">Flutterwave</option>
                    <option value="Cash">Cash</option>
                </select>

                <span asp-validation-for="PaymentChannel" class="text-danger"></span>
            </div>

            <span class="text-danger">@ViewBag.UserError</span>
            <button type="submit" class="btn btn-primary btn-block enter-btn">Add Now</button>
        </form>
    </div>



    <!-- plugins:js -->
    <script src="~/new/assets/vendors/js/vendor.bundle.base.js"></script>
    <!-- endinject -->
    <!-- Plugin js for this page -->
    <script src="~/new/assets/vendors/chart.js/Chart.min.js"></script>
    <script src="~/new/assets/vendors/progressbar.js/progressbar.min.js"></script>
    <script src="~/new/assets/vendors/jvectormap/jquery-jvectormap.min.js"></script>
    <script src="~/new/assets/vendors/jvectormap/jquery-jvectormap-world-mill-en.js"></script>
    <script src="~/new/assets/vendors/owl-carousel-2/owl.carousel.min.js"></script>
    <!-- End plugin js for this page -->
    <!-- inject:js -->
    <script src="~/new/assets/js/off-canvas.js"></script>
    <script src="~/new/assets/js/hoverable-collapse.js"></script>
    <script src="~/new/assets/js/misc.js"></script>
    <script src="~/new/assets/js/settings.js"></script>
    <script src="~/new/assets/js/todolist.js"></script>
    <!-- endinject -->
    <!-- Custom js for this page -->
    <script src="~/new/assets/js/dashboard.js"></script>
    <!-- End custom js for this page -->

     <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>

              function matchCustom(params, data) {
          // If there is no search term, return all results
          if ($.trim(params.term) === '') {
            return data;
          }

          // Do case-insensitive match
          if (data.text.toLowerCase().indexOf(params.term.toLowerCase()) > -1) {
            return data;
          }

          // Return `null` if the term should not be displayed
          return null;
        }

        $(document).ready(function () {
          $('#companySelect').select2({
            placeholder: "-- Select Company --",
            allowClear: true,
             matcher: matchCustom
          });
        });


    </script>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
</body>
</html>

