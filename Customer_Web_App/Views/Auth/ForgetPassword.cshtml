@model Customer_Web_App.Models.ForgetPasswordRequest

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login Page</title>

    <!-- Your CSS file -->
    <link rel="stylesheet" href="~/forms/forms_style.css" />

    <!-- Optional: icons for mail/lock/user/eye -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="shortcut icon" href="~/images/favicon1.png" />
</head>

<body>
    <div class="page">
        <!-- Brand Panel (desktop only) -->
        <aside class="brand">
            <div class="brand-inner">
                <!-- Replace logo.png with your logo path -->
                <img class="logo" src="~/images/logo1.svg" alt="Logo" />
                <h1>Welcome Back</h1>
                <p>Enter your email if you foget the password to recover it again.</p>
            </div>
        </aside>

        <!-- Form Panel -->
        <main class="form">
            <div class="card">
                <!-- Mobile header -->
                <div class="mobile-head">
                    <img class="mobile-logo" src="logo.png" alt="Logo" />
                    <h2>Forget Password</h2>
                </div>

                <!-- Tabs (static UI) -->
                <div class="tabs">
                    <button class="tab active" type="button">Forget Password</button>

                </div>

                <section class="panel">
                    <form asp-action="ForgetPassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <!-- Full Name (hidden in sign-in; keep for sign-up page if you want) -->


                        <div class="field">
                            <label for="email">Email</label>
                            <div class="input-wrap">
                                <i class="fa-regular fa-envelope left"></i>
                                <input asp-for="Email" id="email" type="email" placeholder="you@example.com" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger"></span>
                            <span class="text-danger">@ViewBag.ForgetPasswordError</span>
                        </div>

           

                        <button class="btn primary" type="submit">Submit</button>
                    </form>
                </section>


            </div>
        </main>
    </div>



    <script>
        document.addEventListener("DOMContentLoaded", function () {
          const passwordInput = document.getElementById("password");
          const toggleBtn = document.getElementById("togglePassword");
          const eyeIcon = document.getElementById("eyeIcon");

          if (!passwordInput || !toggleBtn || !eyeIcon) return;

          toggleBtn.addEventListener("click", function () {
            const isHidden = passwordInput.type === "password";
            passwordInput.type = isHidden ? "text" : "password";

            // change icon
            eyeIcon.classList.toggle("fa-eye", !isHidden);
            eyeIcon.classList.toggle("fa-eye-slash", isHidden);

            toggleBtn.setAttribute("aria-label", isHidden ? "Hide password" : "Show password");
          });
        });
    </script>

</body>
</html>


