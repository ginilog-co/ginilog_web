@model Customer_Web_App.Models.ResetPasswordRequest

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password Page</title>

    <!-- Your CSS file -->
    <link rel="stylesheet" href="~/forms/forms_style.css" />

    <!-- Optional: icons for mail/lock/user/eye -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="shortcut icon" href="~/images/favicon1.png" />
</head>

<body>
    <div class="page">
        <!-- Brand Panel (desktop only) -->
        <aside class="brand">
            <div class="brand-inner">
                <!-- Replace logo.png with your logo path -->
                <img class="logo" src="~/images/logo1.svg" alt="Logo" />
                <h1>Welcome Back</h1>
                <p>Enter your token and change your password it again.</p>
            </div>
        </aside>

        <!-- Form Panel -->
        <main class="form">
            <div class="card">
                <!-- Mobile header -->
                <div class="mobile-head">
                    <img class="mobile-logo" src="logo.png" alt="Logo" />
                    <h2>Forget Password</h2>
                </div>

                <!-- Tabs (static UI) -->
                <div class="tabs">
                    <button class="tab active" type="button">Forget Password</button>

                </div>

                <section class="panel">
                    <form asp-action="RessetPassword">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <!-- Full Name (hidden in sign-in; keep for sign-up page if you want) -->


                        <div class="field">
                            <label for="token">Token</label>
                            <div class="input-wrap">
                                <i class="fa-regular fa-envelope left"></i>
                                <input asp-for="Token" id="token" type="text" placeholder="token code here" />
                            </div>
                            <span asp-validation-for="Token" class="text-danger"></span>
                        </div>


                        <div class="field">
                            <label for="password">Password</label>

                            <div class="input-wrap has-right">
                                <i class="fa-solid fa-lock left"></i>

                                <input asp-for="Password" id="password" type="password" placeholder="••••••••" />

                                <!-- static eye icon (no JS) -->
                                <span class="eye" aria-hidden="true">

                                    <button type="button" class="eye-btn" id="togglePassword" aria-label="Show password">
                                        <i class="fa-regular fa-eye" id="eyeIcon"></i>
                                    </button>

                                </span>


                            </div>

                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>


                        <div class="field">
                            <label for="password">Confirm Password</label>

                            <div class="input-wrap has-right">
                                <i class="fa-solid fa-lock left"></i>

                                <input asp-for="ConfirmPassword" id="confirmpassword" type="password" placeholder="••••••••" />


                            </div>

                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>



                        <button class="btn primary" type="submit">Submit</button>
                    </form>
                </section>


            </div>
        </main>
    </div>



    <script>
        document.addEventListener("DOMContentLoaded", function () {
          const passwordInput = document.getElementById("password");
          const toggleBtn = document.getElementById("togglePassword");
          const eyeIcon = document.getElementById("eyeIcon");

          if (!passwordInput || !toggleBtn || !eyeIcon) return;

          toggleBtn.addEventListener("click", function () {
            const isHidden = passwordInput.type === "password";
            passwordInput.type = isHidden ? "text" : "password";

            // change icon
            eyeIcon.classList.toggle("fa-eye", !isHidden);
            eyeIcon.classList.toggle("fa-eye-slash", isHidden);

            toggleBtn.setAttribute("aria-label", isHidden ? "Hide password" : "Show password");
          });
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
          const passwordInput = document.getElementById("confirmpassword");
          const toggleBtn = document.getElementById("togglePassword");
          const eyeIcon = document.getElementById("eyeIcon");

          if (!passwordInput || !toggleBtn || !eyeIcon) return;

          toggleBtn.addEventListener("click", function () {
            const isHidden = passwordInput.type === "password";
            passwordInput.type = isHidden ? "text" : "password";

            // change icon
            eyeIcon.classList.toggle("fa-eye", !isHidden);
            eyeIcon.classList.toggle("fa-eye-slash", isHidden);

            toggleBtn.setAttribute("aria-label", isHidden ? "Hide password" : "Show password");
          });
        });
    </script>

</body>
</html>
