@model Customer_Web_App.Models.LoginRequset

@{
    Layout = null;
}



<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login Page</title>

    <!-- Your CSS file -->
    <link rel="stylesheet" href="~/forms/forms_style.css" />

    <!-- Optional: icons for mail/lock/user/eye -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="shortcut icon" href="~/images/favicon1.png" />
</head>

<body>
    <div class="page">
        <!-- Brand Panel (desktop only) -->
        <aside class="brand">
            <div class="brand-inner">
                <!-- Replace logo.png with your logo path -->
                <img class="logo" src="~/images/logo1.svg" alt="Logo" />
                <h1>Welcome Back</h1>
                <p>Sign in to continue to your dashboard and manage your projects.</p>
            </div>
        </aside>

        <!-- Form Panel -->
        <main class="form">
            <div class="card">
                <!-- Mobile header -->
                <div class="mobile-head">
                    <img class="mobile-logo" src="logo.png" alt="Logo" />
                    <h2>Welcome</h2>
                </div>

                <!-- Tabs (static UI) -->
                <div class="tabs">
                    <button class="tab active" type="button">Sign In</button>
                  
                </div>

                <section class="panel">
                    <form asp-action ="SignIn">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <!-- Full Name (hidden in sign-in; keep for sign-up page if you want) -->
             

                        <div class="field">
                            <label for="email">Email</label>
                            <div class="input-wrap">
                                <i class="fa-regular fa-envelope left"></i>
                                <input asp-for="Email_PhoneNo" id="email" type="email" placeholder="you@example.com" />
                            </div>
                            <span asp-validation-for="Email_PhoneNo" class="text-danger"></span>
                        </div>

                        <div class="field">
                            <label for="password">Password</label>

                            <div class="input-wrap has-right">
                                <i class="fa-solid fa-lock left"></i>

                                <input asp-for="Password" id="password" type="password" placeholder="••••••••" />

                                <!-- static eye icon (no JS) --> 
                                <span class="eye" aria-hidden="true">
                                    
                                    <button type="button" class="eye-btn" id="togglePassword" aria-label="Show password">
                                        <i class="fa-regular fa-eye" id="eyeIcon"></i>
                                    </button>
                                    
                                </span>

                            
                            </div>

                            <span asp-validation-for="Password" class="text-danger"></span>
                            <span class="text-danger">@ViewBag.UserError</span>
                        </div>




                        <div class="row">
                            <a class="link" href="~/Auth/ForgetPassword">Forgot password?</a>
                        </div>

                        <button class="btn primary" type="submit">Sign In</button>
                    </form>
                </section>

                <div class="divider"></div>
                <div class="divider-label"><span>or continue with</span></div>

                <div class="oauth">
                    <button class="btn outline" type="button" onclick="loginWithGoogle()">
                        <svg class="mini" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"
                                  fill="#4285F4" />
                            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                                  fill="#34A853" />
                            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                                  fill="#FBBC05" />
                            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                                  fill="#EA4335" />
                        </svg>
                        Google
                    </button>

                    <button class="btn outline apple-btn" type="button" onclick="loginWithApple()">
                        <svg class="mini"
                             viewBox="0 0 24 24"
                             fill="currentColor"
                             aria-hidden="true">
                            <path d="M16.365 1.43c0 1.14-.42 2.25-1.13 3.06-.75.87-1.98 1.54-3.08 1.45-.14-1.08.39-2.23 1.1-3 .78-.86 2.1-1.49 3.11-1.51.03.14.05.29.05.45zm3.36 16.09c-.84 1.22-1.72 2.43-3.08 2.46-1.33.03-1.76-.8-3.29-.8-1.52 0-2 .77-3.26.83-1.33.05-2.35-1.33-3.2-2.55-1.75-2.54-3.08-7.18-1.29-10.31.89-1.55 2.48-2.54 4.2-2.57 1.31-.03 2.55.89 3.29.89.73 0 2.1-1.1 3.54-.94.6.03 2.29.24 3.38 1.84-.09.05-2.02 1.18-2 3.52.02 2.79 2.44 3.72 2.47 3.73-.02.06-.39 1.34-1.26 2.4z" />
                        </svg>
                        Sign in with Apple
                    </button>

                </div>

                <p class="bottom">
                    Don't have an account?
                    <a href="~/Auth/SignUp">Sign up</a>
                </p>
            </div>
        </main>
    </div>

    <form id="firebaseLoginForm" method="post" asp-action="FirebaseSignIn">
        <input type="hidden" asp-for="IdToken"  id="idTokenField" />
    </form>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
          const passwordInput = document.getElementById("password");
          const toggleBtn = document.getElementById("togglePassword");
          const eyeIcon = document.getElementById("eyeIcon");

          if (!passwordInput || !toggleBtn || !eyeIcon) return;

          toggleBtn.addEventListener("click", function () {
            const isHidden = passwordInput.type === "password";
            passwordInput.type = isHidden ? "text" : "password";

            // change icon
            eyeIcon.classList.toggle("fa-eye", !isHidden);
            eyeIcon.classList.toggle("fa-eye-slash", isHidden);

            toggleBtn.setAttribute("aria-label", isHidden ? "Hide password" : "Show password");
          });
        });
    </script>


    <!-- Firebase SDK (v9 modular) -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.5/firebase-app.js";
        import {
          getAuth,
          GoogleAuthProvider,
          OAuthProvider,
          signInWithPopup,
        } from "https://www.gstatic.com/firebasejs/10.12.5/firebase-auth.js";

        // TODO: replace with your Firebase web config (Project settings -> Web app)
        
        const firebaseConfig = {
          apiKey: "AIzaSyBPmZHEnuc80XMDyPe3KeTYioWH_ZVj3sk",
          authDomain: "ginilog-e3c8a.firebaseapp.com",
          projectId: "ginilog-e3c8a",
          storageBucket: "ginilog-e3c8a.firebasestorage.app",
          messagingSenderId: "701313096073",
          appId: "1:701313096073:web:34be72968f9a14d183e958",
          measurementId: "G-5W6Z8JTRN1"
        };

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);

        // Google
        window.loginWithGoogle = async function () {
          const provider = new GoogleAuthProvider();
          const result = await signInWithPopup(auth, provider);
          const idToken = await result.user.getIdToken();

           submitToMvc(idToken);
        };

        // Apple
        window.loginWithApple = async function () {
          const provider = new OAuthProvider("apple.com");
          provider.addScope("email");
          provider.addScope("name");

          const result = await signInWithPopup(auth, provider);
          const idToken = await result.user.getIdToken();

            submitToMvc(idToken);
        };

            function submitToMvc(idToken) {
            document.getElementById("idTokenField").value = idToken;
            document.getElementById("firebaseLoginForm").submit();
        }
    </script>


</body>
</html>

