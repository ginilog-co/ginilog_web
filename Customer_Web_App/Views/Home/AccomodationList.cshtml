@model IEnumerable<Customer_Web_App.Models.BookingsModel.AccomodationDataModel>

@{
    ViewData["Title"] = "AccomodationList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<!--================Breadcrumb Area =================-->
<section class="breadcrumb_area d-flex align-items-center justify-content-center">
    <div class="overlay bg-parallax"
         data-stellar-ratio="0.8"
         data-stellar-vertical-offset="0"
         data-background="">
    </div>

    <div class="container text-center">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="book_tabel_item">

                    <form asp-action="AccomodationList" method="get">
                        <div class="tracking-group">
                            <input type="text"
                                   name="id"
                                   class="form-control"
                                   placeholder="Search Accommodation here"
                                   required />

                            <button type="submit" class="book_now_btn button_hover">
                                Search
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</section>
<div style="padding-top:20px"></div>
<!--================ Accomodation Area  =================-->
<section class="accomodation_area section_gap">
    <div class="container">
        
        <div class="row accomodation_two">

           @if (Model != null && Model.Any())
            {

            @foreach (var data3 in Model!)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="single-recent-blog-post">
                        <div class="thumb fixed-img">
                            <img class="img-fluid" src="@data3.AccomodationImages![0]" alt="post">
                        </div>
                        <div class="details">
                            <div class="tags">
                                <a href="@Url.Action("AccomodationList", "Home", new { id = data3.AccomodationType })" class="button_hover tag_btn">@data3.AccomodationType</a>

                                <a class="button_hover tag_btn"> ₦@String.Format("{0:N0}", data3.BookingAmount)</a>
                            </div>
                            <a href="@Url.Action("AccomodationDetails", "Home", new { id = data3.Id })"><h4 class="sec_h4">@data3.AccomodationName</h4></a>
                            <p class="one-line-text">@data3.AccomodationDescription</p>
                            <p class="one-line-text">@data3.Location</p>
                        </div>
                    </div>
                </div>
            }

            }
            else
            {
                <p class="text-muted mb-0">No Accomodation yet.</p>
            }
        </div>
    </div>
</section>
<div style="padding-top:20px"></div>
<!--================ Accomodation Area  =================-->