@model Ginilog_Company_WebDasboard.Models.MainAdvertModel

@{
    ViewData["Title"] = "AdvertDetails";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!--Update Shipping Cost-->
<div id="secondModal" class="custom-modal">
    <div class="custom-modal-content">
        <div class="custom-modal-header">
            <h5 style="color:black" class="modal-title">Update Shipping Cost</h5>
            <span style="color:black" class="custom-modal-close" onclick="closeSecondModal()">&times;</span>
        </div>
        <div class="custom-modal-body">

            <form asp-action="UpdateAdvert" enctype="multipart/form-data" method="post">

                <div class="form-group">
                    <label>Advert Image</label>
                    <input id="LogoUpload" asp-for="AddAdvert!.AdvertImage" type="file" accept="image/*" class="form-control" placeholder="Advert Image" />
                </div>
                <div class="form-group">
                    <label>Advert Name</label>
                    <input asp-for="AddAdvert!.AdvertName" type="text" value="@Model.AdvertHolderModel!.AdvertName" class="form-control" placeholder="Advert Name or Title" />
                </div>
                <div class="form-group">
                    <label>Advert Description</label>
                    <textarea asp-for="AddAdvert!.AdvertItemDescription" value="@Model.AdvertHolderModel.AdvertItemDescription" class="form-control" placeholder="Advert Description"></textarea>
                </div>

                <div class="form-group">
                    <label> Advert Days</label>
                    <input asp-for="AddAdvert!.Id!" hidden value="@ViewBag.Id" class="form-control p_input" placeholder=" Advert Days">
                    <input asp-for="AddAdvert!.AdvertDays4!" type="number" value="@Model.AdvertHolderModel.AdvertDays4" class="form-control p_input" placeholder=" Advert Days">

                </div>

                <button type="submit" class="btn btn-primary py-3 w-100 mb-4">Send</button>
            </form>

        </div>
        <div class="custom-modal-footer">
            <button onclick="closeSecondModal()" class="btn-secondary">Cancel</button>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div id="deleteModal" class="custom-modal">
    <div class="custom-modal-content">
        <div class="custom-modal-header">
            <h5 style="color:black" class="modal-title">Confirm Delete</h5>
            <span style="color:black" class="custom-modal-close" onclick="closeModal()">&times;</span>
        </div>
        <div class="custom-modal-body">
            <p style="color:black">   Are you sure you want to delete this Item?</p>

        </div>
        <div class="custom-modal-footer">
            <button onclick="closeModal()" class="btn-secondary">Cancel</button>
            <a href="@Url.Action("DeleteAdvertConfirm", "Home", new { id = Model.AdvertHolderModel!.Id })" class="btn-danger">Delete</a>
        </div>
    </div>
</div>



<div class="row">
    <div class="col-12 grid-margin">
        <div class="card">
            <div class="card-body">

                <div class="row px-0 mx-0">
                    <div class="col-12 grid-margin px-0">
                        <div class="d-flex justify-content-end gap-2 px-0">

                            <div class="col-auto mb-2">
                                <button class="nav-link btn btn-danger create-new-button" onclick="openModal()">Delete</button>
                            </div>
                            <div class="col-auto mb-2">
                                <button onclick="openSecondModal()" class="nav-link btn btn-secondary create-new-button">Update Here</button>
                            </div>
                            @if (Model.AdvertHolderModel.TransStatus == true)
                            {
                                <div class="col-auto mb-2">
                                    <button class="nav-link btn btn-primary create-new-button">Paid</button>
                                </div>
                            }
                            else
                            {
                                <div class="col-auto mb-2">
                                    <a target="_blank" href="@Url.Action("CompleteAdvertPayment", "Home", new { id = Model.AdvertHolderModel!.Id, paymentChannel = "Paystack" })" class="nav-link btn btn-secondary create-new-button">Pay Now(Paystack)</a>
                                </div>
                                <div class="col-auto mb-2">
                                    <a target="_blank" href="@Url.Action("CompleteAdvertPayment", "Home", new { id = Model.AdvertHolderModel!.Id, paymentChannel = "Flutterwave" })" class="nav-link btn btn-secondary create-new-button">Pay Now(Flutterwave)</a>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="row px-0 mx-0">
                    <div class="col-12 grid-margin px-0">
                        <img style="width: 100%; height: auto;" src="@Model.AdvertHolderModel.AdvertImage" alt="profile">
                    </div>
                </div>



                <!-- Sales Chart Start -->

                <div class="row g-4">
                    <div class="col-sm-12 col-xl-4">
                        <div class="card-body">
                            <div class="form-group">
                                <label>Company Name</label>
                                <input style="color: black; background-color: white;" value="@Model.AdminModelTable!.CompanyName" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Manager name</label>
                                <input style="color: black; background-color: white;" value="@Model.AdminModelTable!.FirstName @Model.AdminModelTable.SurName" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Email</label>
                                <p style="color: black; background-color: white;">@Model.AdminModelTable!.Email</p>
                            </div>
                            <div class="form-group">
                                <label>Phone Number</label>
                                <input style="color: black; background-color: white;" value="@Model.AdminModelTable!.PhoneNo" readonly type="text" class="form-control readonly-white">
                            </div>

                            <div class="form-group">
                                <label>Company Types</label>
                                @foreach (var item in Model.AdminModelTable.CompanyType!)
                                {
                                    <p><button class="btn btn-outline-success">@item</button></p>
                                }
                            </div>

                        </div>

                    </div>
                    <div class="col-sm-12 col-xl-4">
                        <div class="card-body">

                            <div class="form-group">
                                <label>Advert Title</label>
                                <input style="color: black; background-color: white;" value="@Model.AdvertHolderModel.AdvertName" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Advert Type</label>
                                <input style="color: black; background-color: white;" value="@Model.AdvertHolderModel.AdvertType" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Advert Description</label>
                                <p style="color: black; background-color: white;">@Model.AdvertHolderModel.AdvertItemDescription</p>
                            </div>
                            <div class="form-group">
                                <label>Advert Cost</label>
                                <input style="color: black; background-color: white;" value="&#8358;@Model.AdvertHolderModel.AdvertItemCost.ToString("N2")" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Trans Ref</label>
                                <input style="color: black; background-color: white;" value="@Model.AdvertHolderModel.TransRef" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Advert Days</label>
                                <input style="color: black; background-color: white;" value="@Model.AdvertHolderModel.AdvertDays4" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Created At</label>
                                <input style="color: black; background-color: white;" value="@Model.AdvertHolderModel.CreatedAt" readonly type="text" class="form-control readonly-white">
                            </div>
                            <div class="form-group">
                                <label>Expired At</label>
                                <input style="color: black; background-color: white;" value="@Model.AdvertHolderModel.ExpiredAt" readonly type="text" class="form-control readonly-white">
                            </div>

                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>

</div>

