@model IEnumerable<Ginilog_Company_WebDasboard.Models.AdvertHolderModel>

@{
    ViewData["Title"] = "AllAdvertData";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-wrapper">
    <div class="row">
        <div class="col-sm-12 mb-4 mb-xl-0">
            <div class="font-weight-normal mb-2 text-muted" id="clock">00:00:00</div>
        </div>
    </div>

    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">

                <div style="padding-top:20px"></div>
                <p>
                    <a asp-action="AddAdvert" class="btn btn-secondary create-new-button">Add Advert</a>
                </p>
                <h6 class="mb-4">Search Here</h6>
                <form asp-controller="Home" asp-action="AllAdvertData" method="get">
                    <div class="form-group">
                        <div class="input-group">
                            <input type="text" class="form-control" name="id" placeholder="Search:  Name, Type or Description or reference" aria-label="Recipient's username" aria-describedby="basic-addon2">
                            <div class="input-group-append">
                                <button class="btn btn-sm btn-primary" type="submit">Search</button>
                            </div>
                        </div>
                    </div>
                </form>

                <div style="padding-top:20px"></div>

                <div class="table-responsive pt-3">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Advert Name</th>
                                <th>Advert Type</th>
                                <th>AdvertItemCost</th>
                                <th>Trans Ref</th>
                                <th>Trans Status</th>
                                <th>Advert Days</th>
                                <th>ExpiredAt</th>
                                <th>Date</th>
                                <th>View</th>
                                <th>Delete</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item!.AdvertName</td>
                                    <td>@item!.AdvertType</td>
                                    <td>&#8358;@item!.AdvertItemCost.ToString("N2")</td>
                                    <td>@item!.TransRef</td>
                                    <td>
                                        @if (item.TransStatus == true)
                                        {
                                            <div class="col-auto mb-2">
                                                <button class="nav-link btn btn-primary create-new-button">Paid</button>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="col-auto mb-2">
                                                <button class="nav-link btn btn-secondary create-new-button">Not Paid</button>
                                            </div>
                                        }
                                    </td>
                                    <td>@item!.AdvertDays4</td>
                                    <td>@item!.ExpiredAt</td>
                                    <td>@item!.CreatedAt</td>
                                    <td><a  href="@Url.Action("AdvertDetails", "Home", new { id = item!.Id })" class="btn btn-outline-info">View</a></td>
                                    <td><a  href="@Url.Action("DeleteAdvert", "Home", new { id = item!.Id })" class="btn btn-danger">Delete</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
