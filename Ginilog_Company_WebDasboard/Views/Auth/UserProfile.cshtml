@model Ginilog_Company_WebDasboard.Models.ProfileData

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>User Profile</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- endinject -->
    <link rel="shortcut icon" href="~/designs/images/favicon.png" />
    <style>
        body {
            background: #f8f9fa;
        }

        .profile-img {
            width: 100px;
            height: 100px;
            object-fit: cover;
            border-radius: 50%;
        }

        .card {
            border: none;
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

        .social-links i {
            margin-right: 10px;
        }

        .progress {
            height: 8px;
        }
    </style>
</head>
<body>

    <div class="container py-5">
        <a href="~/Home/Index" class="btn btn-outline-primary btn-sm">Back to Dashboard</a>
        <div class="row">
            <!-- Left Column -->
            <div class="col-md-4">
                <div class="card text-center mb-3">
                    <div class="card-body">
                        @if (Model.AdminModelTable!.ImagePath != "")
                        {
                            <img class="profile-img mb-3" style="width: 40px; height: 40px;" src="@Model.AdminModelTable!.ImagePath" alt="">
                        }
                        @if (Model.AdminModelTable!.ImagePath == "")
                        {
                            <img class="profile-img mb-3" style="width: 40px; height: 40px;" alt="" src="https://mdbcdn.b-cdn.net/img/Photos/new-templates/bootstrap-chat/ava3.webp">
                        }
                        @if (Model.AdminModelTable!.ImagePath == null)
                        {
                            <img class="profile-img mb-3" style="width: 40px; height: 40px;" alt="" src="https://mdbcdn.b-cdn.net/img/Photos/new-templates/bootstrap-chat/ava3.webp">
                        }
                        <h4>@Model.AdminModelTable!.FirstName @Model.AdminModelTable!.SurName</h4>
                        <p class="text-muted">@Model.AdminModelTable!.AdminType<br>@Model.AdminModelTable!.Branch</p>
                    </div>
                </div>

                <div class="card mb-3">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item"><i class="bi bi-globe"></i> Company <span class="float-end">@Model.AdminModelTable!.CompanyName</span></li>
                        <li class="list-group-item"><i class="bi icon-box-info"></i> UserName <span class="float-end">@Model.AdminModelTable!.CompanyUserName</span></li>
                        <li class="list-group-item"><i class="bi icon-box-info"></i> City <span class="float-end">@Model.AdminModelTable!.Locality</span></li>
                        <li class="list-group-item"><i class="bi icon-box-info"></i> State <span class="float-end">@Model.AdminModelTable!.State</span></li>

                        @foreach (var item in Model.AdminModelTable!.CompanyType!)
                        {
                            <li class="list-group-item"><i class="bi icon-box-info"></i> Company Type <span class="float-end">@item</span></li>
                        }
                       
                    </ul>
                </div>
            </div>

            <!-- Right Column -->
            <div class="col-md-8">
                <div class="card mb-3">
                    <div class="card-body">
                        <h5 class="card-title">User Details</h5>
                        <div class="row">
                            <div class="col-sm-4"><strong>Full Name</strong></div>
                            <div class="col-sm-8 text-muted">@Model.AdminModelTable!.FirstName @Model.AdminModelTable!.SurName</div>
                        </div>
                        <hr>
                        <div class="row">
                            <div class="col-sm-4"><strong>Email</strong></div>
                            <div class="col-sm-8 text-muted">@Model.AdminModelTable!.Email</div>
                        </div>
                        <hr>
                        <div class="row">
                            <div class="col-sm-4"><strong>Phone</strong></div>
                            <div class="col-sm-8 text-muted">@Model.AdminModelTable!.PhoneNo</div>
                        </div>
                        <hr>
                        <div class="row">
                            <div class="col-sm-4"><strong>Staff Code</strong></div>
                            <div class="col-sm-8 text-muted">@Model.AdminModelTable!.StaffCode</div>
                        </div>
                        <hr>
                        <div class="row">
                            <div class="col-sm-4"><strong>Address</strong></div>
                            <div class="col-sm-8 text-muted">@Model.AdminModelTable!.Address</div>
                        </div>
                        <hr>
                        <div class="row">
                            <div class="col-sm-4"><strong>Sex</strong></div>
                            <div class="col-sm-8 text-muted">@Model.AdminModelTable!.Sex</div>
                        </div>
                        <div class="mt-3 text-end">
                            <button class="btn btn-success btn-sm">Edit</button>
                        </div>
                    </div>
                </div>


            </div>
        </div>

    </div>

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

